:2,\\\"tags\\\":\\\"Performance Attendee\\\",\\\"title\\\":\\\"Her solo piano performance at the Java Jazz Festival was mesmerizing. The way she blends contemporary jazz with classical influences creates such unique and emotional music. A true artist!\\\",\\\"userImg\\\":\\\"/images/avatar/review-6.png\\\",\\\"userName\\\":\\\"Marcus Wong\\\",\\\"position\\\":\\\"Festival Director\\\"},{\\\"id\\\":3,\\\"tags\\\":\\\"Composition Client\\\",\\\"title\\\":\\\"Metta composed the perfect score for our documentary. Her orchestral work with the Budapest Scoring Orchestra brought such depth and emotion to our film. Highly professional and incredibly talented.\\\",\\\"userImg\\\":\\\"/images/uploads/1732077798553-1-.jpeg\\\",\\\"userName\\\":\\\"Dr. Lisa Thompson\\\",\\\"position\\\":\\\"Film Producer, CalArts\\\"}]}]}]\\n\"])</script><script>self.__next_f.push([1,\"18:[\\\"$\\\",\\\"section\\\",null,{\\\"id\\\":\\\"blog\\\",\\\"children\\\":[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"z-20 pb-14 pt-14 md:pb-16 md:pt-16 lg:pb-[88px] lg:pt-[88px] xl:pb-[100px] xl:pt-[100px]\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"container\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mb-10 flex flex-col items-start justify-center gap-x-10 gap-y-4 md:mb-20 md:flex-row lg:items-center lg:justify-between\\\",\\\"children\\\":[[\\\"$\\\",\\\"$Lf\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-appear flex-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-instrument italic lg:text-[70px]\\\",\\\"children\\\":\\\"Insights\\\"}],[\\\"$\\\",\\\"br\\\",null,{\\\"className\\\":\\\"hidden lg:block\\\"}],\\\"\\u0026 Stories\\\"]}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex-1 max-md:w-full lg:self-end\\\",\\\"children\\\":[[\\\"$\\\",\\\"$Lf\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-appear max-w-lg md:justify-self-end md