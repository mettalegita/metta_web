,\\\"Rhythm and timing development\\\",\\\"Ear training and musicality\\\",\\\"Classical piano literature\\\",\\\"Jazz and contemporary pieces\\\",\\\"Popular songs and arrangements\\\",\\\"Improvisation and composition basics\\\",\\\"Beginner to advanced level instruction\\\",\\\"Performance preparation and stage confidence\\\",\\\"Technique building and musical expression\\\",\\\"Exam preparation (if desired)\\\"]},{\\\"id\\\":2,\\\"title\\\":\\\"Live Performance\\\",\\\"subtitle\\\":\\\"Solo and ensemble performances for various venues and events\\\",\\\"features\\\":[\\\"Intimate recitals for small venues\\\",\\\"Contemporary and jazz piano sets\\\",\\\"Original composition premieres\\\",\\\"Custom repertoire requests\\\",\\\"Jazz trio and quartet performances\\\",\\\"Chamber music with small ensembles\\\",\\\"Orchestral collaborations\\\",\\\"Cross-disciplinary performance art\\\",\\\"Corporate and private events\\\",\\\"Weddings and celebrations\\\",\\\"Concert halls and theaters\\\",\\\"Festivals and cultural events\\\",\\\"University and school performances\\\"]},{\\\"id\\\":3,\\\"title\\\":\\\"Music Composition\\\",\\\"subtitle\\\":\\\"Original works for various ensembles and media\\\",\\\"features\\\":[\\\"Jazz and contemporary piano works\\\",\\\"Chamber music for small ensembles\\\",\\\"Orchestral arrangements and scoring\\\",\\\"Film and media music composition\\\",\\\"Custom pieces for special occasions\\\",\\\"Initial consultation to understand your vision and requirements\\\",\\\"Composition of original work tailored to your needs\\\",\\\"Professional notation and recording preparation\\\",\\\"Performance-ready scores and parts\\\"]},{\\\"id\\\":4,\\\"title\\\":\\\"Music Education\\\",\\\"subtitle\\\":\\\"School programs, workshops, and educational consulting\\\",\\\"features\\\":[\\\"Curriculum development and implementation\\\",\\\"Teacher training and professional development\\\",\\\"Student assessment and progress tracking\\\",\\\"Concert prepara