# Cloudinary Configuration
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Contact Form SMTP (Hostinger)
# Used by /api/contact to send form submissions
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=metta@mettalegita.com
SMTP_PASS=your_email_password

# Fallback recipient (overridden by data/siteSettings.json contactEmail)
CONTACT_EMAIL=mirzalazuardi@gmail.com

# Google reCAPTCHA v3
# Get keys at: https://www.google.com/recaptcha/admin
# Choose reCAPTCHA v3, add your domain (mettalegita.com)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
